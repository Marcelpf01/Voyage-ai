# Environment Variables — Voyage AI

# Copy this file to .env and fill in your values.
# Only VITE_-prefixed variables are bundled into the client.

# ── Required ──────────────────────────────────────────

# Rork Toolkit URL (AI proxy endpoint)
VITE_TOOLKIT_URL=https://toolkit.rork.app

# Rork Toolkit secret key
VITE_RORK_TOOLKIT_SECRET_KEY=your-toolkit-secret-key

# ── Optional — Firebase ───────────────────────────────
# Uncomment and fill in if using Firebase instead of local auth.

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ── Optional — Google Maps ────────────────────────────
# VITE_GOOGLE_MAPS_API_KEY=

# ── Optional — Gemini (direct API) ────────────────────
# VITE_GEMINI_API_KEY=
